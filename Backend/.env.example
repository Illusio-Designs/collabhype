# --- Server ---
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# --- Database (MySQL) ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/collabcreator"

# --- Auth ---
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- CORS ---
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
FRONTEND_BASE_URL=http://localhost:3000

# --- Razorpay (payments + escrow + payouts) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Instagram (Meta Graph API) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/v1/oauth/instagram/callback

# --- YouTube (Google API) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/oauth/youtube/callback

# --- Storage (later: S3 / Cloudinary for content uploads) ---
# AWS_REGION=
# AWS_S3_BUCKET=
