# Base URL of the Collabhype backend API (without the /api/v1 suffix — the app
# appends it). Expo inlines EXPO_PUBLIC_* variables at build time.
#
# Local dev (Android emulator uses 10.0.2.2 to reach the host machine):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
# Physical device on the same network:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:4000
# Production:
#   EXPO_PUBLIC_API_BASE_URL=https://api.collabhype.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
