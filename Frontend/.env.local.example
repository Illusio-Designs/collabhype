# =========================================================================
# Collabhype Frontend — environment variables
# =========================================================================
# When deploying to Vercel with no backend, leave NEXT_PUBLIC_API_BASE_URL
# empty: the app will run in DEMO MODE and serve dummy data for every API
# call. Demo mode is also forced when NEXT_PUBLIC_DEMO_MODE=1.

# Set NEXT_PUBLIC_API_BASE_URL to your backend (e.g. http://localhost:4000)
# to opt out of demo mode and use the real API.
NEXT_PUBLIC_API_BASE_URL=

# Force demo mode regardless of API URL (1 = on, anything else = off).
NEXT_PUBLIC_DEMO_MODE=1

# Razorpay public key (used by checkout flow when wired to a real backend).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
